<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController" stylesheets="@login.css">
    <VBox styleClass="login-container" alignment="CENTER_LEFT">
        <Label styleClass="login-title" text="Welcome Back" />
        <Label styleClass="login-subtitle" text="Sign in to your FarmConnect account" />

        <Region prefHeight="8" />

        <Label styleClass="form-label" text="Email" />
        <TextField fx:id="emailField" styleClass="input-field" promptText="you@example.com" />
        <Label fx:id="emailError" styleClass="error-label" managed="false" />

        <Label styleClass="form-label" text="Password" />
        <PasswordField fx:id="passwordField" styleClass="input-field" promptText="Enter your password" />
        <Label fx:id="passwordError" styleClass="error-label" managed="false" />

        <Label fx:id="generalError" styleClass="error-label" managed="false" />

        <HBox alignment="CENTER_LEFT" spacing="0">
            <CheckBox fx:id="rememberCheck" styleClass="checkbox" text="Remember me" />
            <Region HBox.hgrow="ALWAYS" />
            <Hyperlink styleClass="forgot-link" text="Forgot password?" />
        </HBox>

        <Region prefHeight="4" />

        <Button fx:id="loginBtn" styleClass="btn-login" text="Sign In" maxWidth="Infinity" onAction="#onLogin" />

        <Region prefHeight="8" />

        <HBox alignment="CENTER" spacing="4">
            <Label styleClass="bottom-link" text="Don&apos;t have an account?" />
            <Hyperlink styleClass="bottom-link" text="Register" onAction="#onRegister" />
        </HBox>
    </VBox>
</VBox>
