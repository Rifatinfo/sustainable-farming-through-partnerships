<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InvestorRegisterController" stylesheets="@investor_register.css">
    <VBox styleClass="register-container" alignment="CENTER_LEFT">
        <Label styleClass="register-title" text="Create Account" />
        <Label styleClass="register-subtitle" text="Join FarmConnect as an Investor" />

        <Region prefHeight="6" />

        <Label styleClass="form-label" text="Full Name" />
        <TextField fx:id="nameField" styleClass="input-field" promptText="John Doe" />
        <Label fx:id="nameError" styleClass="error-label" managed="false" />

        <Label styleClass="form-label" text="Email" />
        <TextField fx:id="emailField" styleClass="input-field" promptText="you@example.com" />
        <Label fx:id="emailError" styleClass="error-label" managed="false" />

        <Label styleClass="form-label" text="Password" />
        <PasswordField fx:id="passwordField" styleClass="input-field" promptText="At least 6 characters" />
        <Label fx:id="passwordError" styleClass="error-label" managed="false" />

        <Label styleClass="form-label" text="Confirm Password" />
        <PasswordField fx:id="confirmField" styleClass="input-field" promptText="Re-enter your password" />
        <Label fx:id="confirmError" styleClass="error-label" managed="false" />

        <Label fx:id="generalError" styleClass="error-label" managed="false" />
        <Label fx:id="successLabel" styleClass="success-label" managed="false" />

        <Region prefHeight="4" />

        <Button fx:id="registerBtn" styleClass="btn-register" text="Create Account" maxWidth="Infinity" onAction="#onRegister" />

        <Region prefHeight="8" />

        <HBox alignment="CENTER" spacing="4">
            <Label styleClass="bottom-link" text="Already have an account?" />
            <Hyperlink styleClass="bottom-link" text="Sign In" onAction="#onLogin" />
        </HBox>
    </VBox>
</VBox>
